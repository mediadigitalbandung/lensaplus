# Database (Local PostgreSQL)
DATABASE_URL="postgresql://kartawarta:password@localhost:5432/kartawarta"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Setup key (for initial database seeding via /api/setup?key=YOUR_KEY)
SETUP_KEY="your-setup-key-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kartawarta"

# Cron Secret (for scheduled publishing — used by systemd/cron on VPS)
CRON_SECRET="your-cron-secret-here"

# Obsidian editorial vault sync token (used by tools/sync-obsidian.mjs)
# Generate: openssl rand -hex 32
OBSIDIAN_SYNC_TOKEN=""

# Sentry error tracking (optional — auto-disabled if empty)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Email (Resend — https://resend.com, free 100/day)
RESEND_API_KEY="re_your-api-key-here"
EMAIL_FROM="Kartawarta <noreply@kartawarta.com>"

# Upload safety — block /api/upload when dev runtime is connected to prod DB.
# Comma-separated host substrings to look for in DATABASE_URL.
# Override only if your prod host changes; default is safe for Kartawarta.
BLOCKED_PROD_DB_HOSTS="145.79.15.99,kartawarta.com"

# Object storage (Cloudflare R2 or any S3-compatible) — OPTIONAL.
# Leave empty to keep saving uploads to /public/uploads/ on the local
# filesystem (current default). When all four are set, swap the storage
# driver in src/lib/storage/index.ts to r2.ts (to be implemented).
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public URL prefix that R2 objects are served from (custom domain or *.r2.dev)
R2_PUBLIC_URL_BASE=""

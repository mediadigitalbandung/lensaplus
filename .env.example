# Database (Local PostgreSQL)
DATABASE_URL="postgresql://kartawarta:password@localhost:5432/kartawarta"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Setup key (for initial database seeding via /api/setup?key=YOUR_KEY)
SETUP_KEY="your-setup-key-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kartawarta"

# Cron Secret (for scheduled publishing — used by systemd/cron on VPS)
CRON_SECRET="your-cron-secret-here"

# Obsidian editorial vault sync token (used by tools/sync-obsidian.mjs)
# Generate: openssl rand -hex 32
OBSIDIAN_SYNC_TOKEN=""

# Sentry error tracking (optional — auto-disabled if empty)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Email (Resend — https://resend.com, free 100/day)
RESEND_API_KEY="re_your-api-key-here"
EMAIL_FROM="Kartawarta <noreply@kartawarta.com>"

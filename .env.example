# Database (Local PostgreSQL)
DATABASE_URL="postgresql://lensaplus:password@localhost:5432/lensaplus"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Setup key (for initial database seeding via /api/setup?key=YOUR_KEY)
SETUP_KEY="your-setup-key-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Lensaplus"

# Cron Secret (for scheduled publishing — used by systemd/cron on VPS)
CRON_SECRET="your-cron-secret-here"

# Obsidian editorial vault sync token (used by tools/sync-obsidian.mjs)
# Generate: openssl rand -hex 32
OBSIDIAN_SYNC_TOKEN=""

# Sentry error tracking (optional — auto-disabled if empty)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Email (Resend — https://resend.com, free 100/day)
RESEND_API_KEY="re_your-api-key-here"
EMAIL_FROM="Lensaplus <noreply@lensaplus.com>"

# Upload safety — block /api/upload when dev runtime is connected to prod DB.
# Comma-separated host substrings to look for in DATABASE_URL.
# Override only if your prod host changes; default is safe for Lensaplus.
BLOCKED_PROD_DB_HOSTS="145.79.15.99,lensaplus.com"

# Object storage (Cloudflare R2 or any S3-compatible) — OPTIONAL.
# Leave empty to keep saving uploads to /public/uploads/ on the local
# filesystem (current default). When all four are set, swap the storage
# driver in src/lib/storage/index.ts to r2.ts (to be implemented).
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public URL prefix that R2 objects are served from (custom domain or *.r2.dev)
R2_PUBLIC_URL_BASE=""

# Google AdSense (Optional - fallback is ca-pub-5936356841993880)
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-5936356841993880"

# Publisher identity — transparency signals for Google News / Dewan Pers.
# These flow into the NewsMediaOrganization JSON-LD (src/lib/seo/json-ld.ts),
# the /kontak phone, and (when set) the /tentang publisher block. They render
# ONLY when set — never with placeholder/fabricated values. Fill with the REAL
# operating data before submitting for Google News / Dewan Pers verification.
NEXT_PUBLIC_PUBLISHER_LEGAL_NAME=""   # e.g. "PT Media Digital Bandung"
NEXT_PUBLIC_PUBLISHER_PHONE=""         # e.g. "+62 22 1234567" (WA/phone)
NEXT_PUBLIC_PUBLISHER_STREET=""        # e.g. "Jl. ... No. 10"
NEXT_PUBLIC_PUBLISHER_POSTAL=""        # e.g. "40115"
NEXT_PUBLIC_PUBLISHER_FOUNDING=""      # e.g. "2024" (year founded)


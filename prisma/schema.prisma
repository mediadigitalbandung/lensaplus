generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CHIEF_EDITOR
  EDITOR
  SENIOR_JOURNALIST
  JOURNALIST
  CONTRIBUTOR
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum VerificationLabel {
  VERIFIED
  UNVERIFIED
  CORRECTION
  OPINION
}

enum ReportReason {
  HOAX
  INACCURATE
  SARA
  DEFAMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum AdType {
  IMAGE
  GIF
  HTML
}

enum AdSlot {
  HEADER
  SIDEBAR
  IN_ARTICLE
  FOOTER
  BETWEEN_SECTIONS
  POPUP
  FLOATING_BOTTOM
}

enum SorotanAngle {
  KRONOLOGI
  ANALISIS
  DAMPAK
  LATAR_BELAKANG
  PROFIL
  REAKSI
  HUKUM
  EKONOMI
  PROYEKSI
  FAQ
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TWITTER
}

enum SocialPostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  DELETED
}

enum CourtScheduleStatus {
  SCHEDULED
  LIVE
  DONE
  CANCELLED
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  password         String
  name             String
  avatar           String?
  bio              String?
  role             Role       @default(JOURNALIST)
  specialization   String?
  phone            String?
  nomorKartuPers   String?
  organisasiPers   String?
  pendidikan       String?
  pengalaman       String?    @db.Text
  keahlian         String?
  portofolio       String?
  mediaSosial      String?
  alamat           String?
  isActive         Boolean    @default(true)
  twoFactorEnabled Boolean    @default(false)
  activeSessionId  String?
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  articles         Article[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Article {
  id                 String            @id @default(cuid())
  title              String
  slug               String            @unique
  content            String            @db.Text
  excerpt            String?
  featuredImage      String?
  status             ArticleStatus     @default(DRAFT)
  verificationLabel  VerificationLabel @default(UNVERIFIED)
  readTime           Int?
  viewCount          Int               @default(0)
  publishedAt        DateTime?
  scheduledAt        DateTime?
  seoTitle           String?
  seoDescription     String?
  author             User              @relation(fields: [authorId], references: [id])
  authorId           String
  category           Category          @relation(fields: [categoryId], references: [id])
  categoryId         String
  tags               Tag[]
  sources            Source[]
  corrections        Correction[]
  reports            Report[]
  revisions          Revision[]
  comments           Comment[]
  reviewNote         String?
  reviewedBy         String?
  reviewedAt         DateTime?
  assignedEditorId   String?
  coAuthors          String?
  isAutoGenerated    Boolean           @default(false)
  sourceArticleId    String?
  publishToInstagram Boolean?
  publishToFacebook  Boolean?
  publishToTwitter   Boolean?
  socialCaptions     Json?
  faqData            String?           @db.Text
  indexStatus        String?           @default("pending")
  lastIndexedAt      DateTime?
  sorotan            Sorotan[]
  socialPosts        SocialPost[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([assignedEditorId])
  @@index([indexStatus])
  @@index([isAutoGenerated])
  @@map("articles")
}

model Category {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  description     String?
  icon            String?
  order           Int              @default(0)
  articles        Article[]
  polls           Poll[]
  socialTemplates SocialTemplate[]
  targetKeywords  TargetKeyword[]
  newsSources     NewsSource[]

  @@map("categories")
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]

  @@map("tags")
}

model Source {
  id          String  @id @default(cuid())
  name        String
  title       String?
  institution String?
  url         String?
  article     Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String

  @@map("sources")
}

model Correction {
  id          String   @id @default(cuid())
  description String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String
  createdAt   DateTime @default(now())

  @@map("corrections")
}

model Revision {
  id        String   @id @default(cuid())
  content   String   @db.Text
  title     String
  changedBy String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  createdAt DateTime @default(now())

  @@map("revisions")
}

model Report {
  id        String       @id @default(cuid())
  reason    ReportReason
  detail    String?
  email     String?
  status    ReportStatus @default(PENDING)
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  createdAt DateTime     @default(now())

  @@map("reports")
}

model Ad {
  id          String   @id @default(cuid())
  name        String
  type        AdType
  imageUrl    String?
  htmlCode    String?  @db.Text
  targetUrl   String?
  slot        AdSlot
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  targetPages String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ads")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  detail    String?
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model AIUsageLog {
  id           String   @id @default(cuid())
  userId       String
  userName     String
  feature      String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  articleTitle String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("ai_usage_logs")
}

model Comment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  authorName  String
  authorEmail String
  isApproved  Boolean  @default(false)
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String
  parentId    String?
  createdAt   DateTime @default(now())

  @@index([articleId])
  @@map("comments")
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  url          String   @db.Text
  type         String
  size         Int
  title        String?
  caption      String?  @db.Text
  credit       String?
  uploadedBy   String
  uploaderName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([uploadedBy])
  @@map("media")
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "article_approved", "article_rejected", "article_published", "article_submitted", "new_review"
  title     String
  message   String
  link      String? // URL to navigate to
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model RedaksiMember {
  id        String   @id @default(cuid())
  position  String
  name      String
  desc      String?
  photo     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("redaksi_members")
}

model Poll {
  id         String       @id @default(cuid())
  question   String
  image      String?
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id])
  isActive   Boolean      @default(true)
  order      Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  options    PollOption[]

  @@map("polls")
}

model PollOption {
  id        String     @id @default(cuid())
  label     String
  votes     Int        @default(0)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String
  pollVotes PollVote[]

  @@map("poll_options")
}

model PollVote {
  id          String     @id @default(cuid())
  optionId    String
  option      PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  ip          String
  fingerprint String?
  createdAt   DateTime   @default(now())

  @@unique([optionId, ip])
  @@index([ip])
  @@map("poll_votes")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Sorotan {
  id            String       @id @default(cuid())
  slug          String       @unique
  article       Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId     String
  angle         SorotanAngle
  title         String
  content       String       @db.Text
  indexStatus   String?      @default("pending")
  lastIndexedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([articleId])
  @@index([indexStatus])
  @@map("sorotan")
}

model SocialPost {
  id           String           @id @default(cuid())
  article      Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId    String
  platform     SocialPlatform
  status       SocialPostStatus
  externalId   String?
  imageUrl     String?
  caption      String?          @db.Text
  publishedAt  DateTime?
  errorMessage String?
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([articleId])
  @@index([platform, status])
  @@map("social_posts")
}

model SocialTemplate {
  id            String         @id @default(cuid())
  name          String
  platform      SocialPlatform
  category      Category?      @relation(fields: [categoryId], references: [id])
  categoryId    String?
  backgroundUrl String         @db.Text
  textLayers    Json
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([platform, isActive])
  @@map("social_templates")
}

model SocialMediaSettings {
  id                 String   @id @default("global")
  draftMode          Boolean  @default(true)
  autoPublishIG      Boolean  @default(false)
  autoPublishFB      Boolean  @default(false)
  autoPublishTwitter Boolean  @default(false)
  defaultHashtags    String?  @db.Text
  defaultCTA         String?  @db.Text
  updatedAt          DateTime @updatedAt

  @@map("social_media_settings")
}

model InstagramSettings {
  id                String    @id @default("global")
  accessToken       String?   @db.Text
  igUserId          String?
  templateDefaultId String?
  enabled           Boolean   @default(false)
  captionMaxLen     Int       @default(2200)
  hashtagCount      Int       @default(15)
  tokenExpiresAt    DateTime?
  updatedAt         DateTime  @updatedAt

  @@map("instagram_settings")
}

model FacebookSettings {
  id                String    @id @default("global")
  pageId            String?
  accessToken       String?   @db.Text
  postMode          String    @default("link")
  templateDefaultId String?
  enabled           Boolean   @default(false)
  tokenExpiresAt    DateTime?
  updatedAt         DateTime  @updatedAt

  @@map("facebook_settings")
}

model CourtSchedule {
  id          String              @id @default(cuid())
  caseName    String
  caseNumber  String?
  courtName   String
  scheduledAt DateTime
  status      CourtScheduleStatus @default(SCHEDULED)
  notes       String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([scheduledAt])
  @@index([status])
  @@map("court_schedules")
}

model TargetKeyword {
  id              String    @id @default(cuid())
  keyword         String    @unique
  category        Category? @relation(fields: [categoryId], references: [id])
  categoryId      String?
  priority        Int       @default(0)
  isActive        Boolean   @default(true)
  lastGeneratedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, priority])
  @@map("target_keywords")
}

/// External news source the cron should periodically scrape, paraphrase
/// and turn into Kartawarta drafts. One row per upstream listing URL
/// (e.g. https://www.bankbjb.co.id/page/berita).
model NewsSource {
  id               String    @id @default(cuid())
  name             String
  listingUrl       String    @unique
  category         Category? @relation(fields: [categoryId], references: [id])
  categoryId       String?
  description      String?
  isActive         Boolean   @default(true)
  priority         Int       @default(0)
  /// How often the cron should re-check this source. Range 1–24 hours.
  frequencyHours   Int       @default(4)
  /// Render JavaScript via headless Chromium before scraping. Required for
  /// SPA sites (e.g. bankbjb.co.id) whose article cards are injected by
  /// client-side JS. Roughly 5–10× slower than the static fetcher.
  useHeadless      Boolean   @default(false)
  /// CSS selector to wait for after the page loads when in headless mode.
  /// Helps with lazy-loaded listings.
  waitForSelector  String?
  /// Optional manual CSS selectors when auto-detect fails.
  articleSelector  String?
  titleSelector    String?
  contentSelector  String?
  imageSelector    String?
  /// URLs we have already paraphrased — used to dedup.
  scrapedUrls      String[]  @default([])
  totalScraped     Int       @default(0)
  defaultTags      String[]  @default([])
  lastCheckedAt    DateTime?
  lastSuccessAt    DateTime?
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isActive, priority])
  @@map("news_sources")
}

model CtaTemplate {
  id        String   @id @default(cuid())
  name      String
  html      String   @db.Text
  position  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cta_templates")
}

enum GlossaryRanah {
  PIDANA
  PERDATA
  HTN
  HI
  PROSEDUR
  UMUM
}

model Glossary {
  id           String        @id @default(cuid())
  slug         String        @unique
  istilah      String
  singkatan    String?
  bahasaAsli   String?       @map("bahasa_asli")
  ranah        GlossaryRanah @default(UMUM)
  // Body in HTML (sanitized) — sync script converts markdown → HTML
  bodyHtml     String        @db.Text
  // Source markdown for diff/audit when re-syncing
  bodyMarkdown String?       @db.Text
  // Tags for filter (e.g., ["pidana", "kuhap"])
  tags         String[]      @default([])
  // Cross-link: related glossary slugs
  related      String[]      @default([])
  // Source file path in editorial vault
  sourcePath   String?
  // Visibility — admin can hide drafts
  isPublished  Boolean       @default(true)
  viewCount    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ranah, isPublished])
  @@index([istilah])
  @@map("glossary")
}

// ─────────────────────────────────────────────────────────────────────────────
// TikTok Automation
// ─────────────────────────────────────────────────────────────────────────────
// Phase 1 (current): manual workflow — staff upload media, set caption/hashtags/music,
//   export ZIP for posting via TikTok mobile app or CapCut. NO direct API posting yet.
// Phase 2 (next): auto-render videos via @heygen-com/hyperframes from chosen template.
// Phase 3 (next): direct posting via TikTok Content Posting API (requires audit).
// See docs/TIKTOK_AUTOMATION.md for full plan.

enum TiktokAccountStatus {
  CONNECTED
  TOKEN_EXPIRED
  REVOKED
}

enum TiktokContentStatus {
  DRAFT          // staff still editing
  READY          // ready to export / queue render
  RENDERING      // Phase 2: hyperframes job running
  RENDER_FAILED  // Phase 2: render error
  SCHEDULED      // queued for autopost at scheduledAt
  PUBLISHING     // Phase 3: API upload in progress
  PUBLISHED      // Phase 3: live on TikTok
  PUBLISH_FAILED // Phase 3: API upload error
  ARCHIVED
}

enum TiktokAspectRatio {
  PORTRAIT_9_16  // 1080x1920 — default TikTok feed
  SQUARE_1_1     // 1080x1080
}

enum TiktokMediaKind {
  IMAGE
  VIDEO
}

model TiktokAccount {
  id             String              @id @default(cuid())
  // Owner is the Kartawarta staff user who connected the TikTok handle.
  ownerId        String
  ownerName      String
  // TikTok-side identifiers (filled in Phase 3 after OAuth)
  platformUserId String?             @unique
  username       String              // e.g. "kartawarta_id"
  displayName    String
  avatarUrl      String?
  scopes         String              @default("") // comma-sep
  accessToken    String?             @db.Text
  refreshToken   String?             @db.Text
  expiresAt      DateTime?
  status         TiktokAccountStatus @default(CONNECTED)
  contents       TiktokContent[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([ownerId])
  @@map("tiktok_accounts")
}

model TiktokContent {
  id              String              @id @default(cuid())
  accountId       String?
  account         TiktokAccount?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  // Editorial fields
  title           String              // internal label for staff
  caption         String?             @db.Text  // TikTok caption (max 2200)
  hashtags        String              @default("") // comma-sep, "hukum,bandung"
  // Optional: derived from / linked to an Article
  sourceArticleId String?
  // Output settings
  aspectRatio     TiktokAspectRatio   @default(PORTRAIT_9_16)
  duration        Int?                // seconds, set after render
  templateKey     String?             // matches TiktokTemplate.key (Phase 2)
  // Render output (Phase 2)
  outputUrl       String?
  thumbnailUrl    String?
  // Audio
  bgmUrl          String?
  bgmVolume       Float               @default(0.6)
  // Overlay & per-slot text — flexible JSON
  overlayJson     Json?
  // Lifecycle
  status          TiktokContentStatus @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  platformPostId  String?
  publishError    String?             @db.Text
  // Authorship
  createdById     String
  createdByName   String
  slots           TiktokMediaSlot[]
  renderJobs      TiktokRenderJob[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([accountId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdById])
  @@map("tiktok_contents")
}

model TiktokMediaSlot {
  id          String          @id @default(cuid())
  contentId   String
  content     TiktokContent   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  order       Int             @default(0)
  kind        TiktokMediaKind
  url         String          @db.Text
  filename    String?
  mimeType    String?
  // Display tuning
  durationMs  Int             @default(3000) // image: total on-screen, video: ignored
  trimStartMs Int             @default(0)
  trimEndMs   Int?
  caption     String?         @db.Text       // optional text overlay for this slot
  width       Int?
  height      Int?
  size        Int?
  createdAt   DateTime        @default(now())

  @@index([contentId])
  @@index([contentId, order])
  @@map("tiktok_media_slots")
}

model TiktokTemplate {
  id            String            @id @default(cuid())
  // Stable identifier used by hyperframes renderer (Phase 2)
  key           String            @unique
  name          String
  description   String?           @db.Text
  // Path on disk to the HTML template (resolved by render worker, Phase 2)
  htmlPath      String?
  // Slot rules
  minSlots      Int               @default(1)
  maxSlots      Int               @default(10)
  acceptedKinds String            @default("IMAGE,VIDEO")
  aspectRatio   TiktokAspectRatio @default(PORTRAIT_9_16)
  thumbnailUrl  String?
  isActive      Boolean           @default(true)
  order         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("tiktok_templates")
}

model TiktokRenderJob {
  id           String        @id @default(cuid())
  contentId    String
  content      TiktokContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  status       String        @default("QUEUED") // QUEUED, RUNNING, SUCCEEDED, FAILED
  progress     Int           @default(0)
  outputUrl    String?
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?       @db.Text
  workerId     String?
  createdAt    DateTime      @default(now())

  @@index([contentId])
  @@index([status])
  @@map("tiktok_render_jobs")
}

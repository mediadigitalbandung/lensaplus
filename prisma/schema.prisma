generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CHIEF_EDITOR
  EDITOR
  SENIOR_JOURNALIST
  JOURNALIST
  CONTRIBUTOR
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum VerificationLabel {
  VERIFIED
  UNVERIFIED
  CORRECTION
  OPINION
}

enum ReportReason {
  HOAX
  INACCURATE
  SARA
  DEFAMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum AdType {
  IMAGE
  GIF
  HTML
}

enum AdSlot {
  HEADER
  SIDEBAR
  IN_ARTICLE
  FOOTER
  BETWEEN_SECTIONS
  POPUP
  FLOATING_BOTTOM
}

enum SorotanAngle {
  KRONOLOGI
  ANALISIS
  DAMPAK
  LATAR_BELAKANG
  PROFIL
  REAKSI
  HUKUM
  EKONOMI
  PROYEKSI
  /// 114 legacy Sorotan rows in production use FAQ angle (2026-04 era).
  /// sorotan-generator.ts no longer produces new FAQ entries — new FAQ
  /// content lives in Article.faqData (separate field). Enum value
  /// retained for backward-read compatibility. Sprint 3 attempted drop
  /// but rolled back after discovering 114 valid rows.
  FAQ
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TWITTER
}

enum SocialPostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  DELETED
}

enum CourtScheduleStatus {
  SCHEDULED
  LIVE
  DONE
  CANCELLED
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  password         String
  name             String
  avatar           String?
  bio              String?
  role             Role       @default(JOURNALIST)
  specialization   String?
  phone            String?
  nomorKartuPers   String?
  organisasiPers   String?
  pendidikan       String?
  pengalaman       String?    @db.Text
  keahlian         String?
  portofolio       String?
  mediaSosial      String?
  alamat           String?
  isActive         Boolean    @default(true)
  twoFactorEnabled Boolean    @default(false) // TODO: 2FA placeholder — field exists but is never read by auth flow. Keep until 2FA sprint.
  activeSessionId  String?
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  articles         Article[]
  auditLogs        AuditLog[]
  liveBlogs        LiveBlog[]

  @@map("users")
}

model Article {
  id                 String            @id @default(cuid())
  title              String
  slug               String            @unique
  content            String            @db.Text
  excerpt            String?
  featuredImage      String?
  status             ArticleStatus     @default(DRAFT)
  verificationLabel  VerificationLabel @default(UNVERIFIED)
  readTime           Int?
  viewCount          Int               @default(0)
  publishedAt        DateTime?
  scheduledAt        DateTime?
  seoTitle           String?
  seoDescription     String?
  author             User              @relation(fields: [authorId], references: [id], onDelete: Restrict)
  authorId           String
  category           Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId         String
  tags               Tag[]
  sources            Source[]
  corrections        Correction[]
  reports            Report[]
  revisions          Revision[]
  comments           Comment[]
  reviewNote         String?
  reviewedBy         String?
  reviewedAt         DateTime?
  assignedEditorId   String?
  coAuthors          String? // CSV: e.g. "Andi, Budi". Display-only — no FK to User. Future: convert to many-to-many ArticleAuthor junction table.
  isAutoGenerated    Boolean           @default(false)
  sourceArticleId    String?
  publishToInstagram Boolean?
  publishToFacebook  Boolean?
  publishToTwitter   Boolean?
  socialCaptions     Json?
  faqData            String?           @db.Text
  indexStatus        String?           @default("pending")
  /// Last error message captured when indexStatus became "failed". Helps the
  /// SEO panel surface WHY a submission failed (most common: service account
  /// not added as Owner in Google Search Console → "Permission denied.
  /// Failed to verify the URL ownership."). Null when last attempt succeeded.
  indexLastError     String?
  lastIndexedAt      DateTime?
  sorotan            Sorotan[]
  socialPosts        SocialPost[]
  reactions          ArticleReaction[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([authorId])
  @@index([categoryId])
  @@index([assignedEditorId])
  @@index([indexStatus])
  // Composite for homepage/category listing: WHERE status=PUBLISHED ORDER BY publishedAt DESC.
  // Replaces the now-redundant standalone @@index([status]) and @@index([publishedAt]).
  @@index([status, publishedAt])
  // Composite for trending block: WHERE status=PUBLISHED ORDER BY viewCount DESC.
  @@index([status, viewCount(sort: Desc)])
  @@index([isAutoGenerated])
  @@map("articles")
}

model Category {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  description     String?
  icon            String?
  order           Int              @default(0)
  articles        Article[]
  polls           Poll[]
  socialTemplates SocialTemplate[]
  targetKeywords  TargetKeyword[]
  newsSources     NewsSource[]

  @@map("categories")
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]
  topics   Topic[]

  @@map("tags")
}

model Topic {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String   @db.Text
  metaTitle       String?
  metaDescription String?  @db.Text
  coverImage      String?
  isPublished     Boolean  @default(true)
  tags            Tag[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublished])
  @@map("topics")
}

model Source {
  id          String  @id @default(cuid())
  name        String
  title       String?
  institution String?
  url         String?
  article     Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String

  @@index([articleId])
  @@map("sources")
}

model Correction {
  id          String   @id @default(cuid())
  description String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String
  createdAt   DateTime @default(now())

  @@index([articleId])
  @@map("corrections")
}

model Revision {
  id        String   @id @default(cuid())
  content   String   @db.Text
  title     String
  changedBy String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  createdAt DateTime @default(now())

  @@index([articleId])
  @@map("revisions")
}

model Report {
  id        String       @id @default(cuid())
  reason    ReportReason
  detail    String?
  email     String?
  status    ReportStatus @default(PENDING)
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  createdAt DateTime     @default(now())

  @@index([articleId])
  @@map("reports")
}

model Ad {
  id          String   @id @default(cuid())
  name        String
  type        AdType
  imageUrl    String?
  htmlCode    String?  @db.Text
  targetUrl   String?
  slot        AdSlot
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  targetPages String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ads")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  detail    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model AIUsageLog {
  id           String   @id @default(cuid())
  userId       String
  userName     String
  feature      String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  articleTitle String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("ai_usage_logs")
}

model Comment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  authorName  String
  authorEmail String
  isApproved  Boolean  @default(false)
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String
  parentId    String?
  createdAt   DateTime @default(now())

  @@index([articleId])
  @@map("comments")
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  url          String   @db.Text
  type         String
  size         Int
  title        String?
  caption      String?  @db.Text
  credit       String?
  uploadedBy   String
  uploaderName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([uploadedBy])
  @@map("media")
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "article_approved", "article_rejected", "article_published", "article_submitted", "new_review"
  title     String
  message   String
  link      String? // URL to navigate to
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model RedaksiMember {
  id        String   @id @default(cuid())
  position  String
  name      String
  desc      String?
  photo     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("redaksi_members")
}

model Poll {
  id         String       @id @default(cuid())
  question   String
  image      String?
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isActive   Boolean      @default(true)
  order      Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  options    PollOption[]

  @@index([categoryId])
  @@map("polls")
}

model PollOption {
  id        String     @id @default(cuid())
  label     String
  votes     Int        @default(0)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String
  pollVotes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id          String     @id @default(cuid())
  optionId    String
  option      PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  ip          String
  fingerprint String?
  createdAt   DateTime   @default(now())

  @@unique([optionId, ip])
  @@index([ip])
  @@map("poll_votes")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

/// Newsletter subscribers — opt-in email list for weekly digest.
/// Double-opt-in pattern: confirmedAt is null until the user clicks the
/// confirmation link sent to their email.
model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  /// Opaque token for confirm + unsubscribe links. Regenerated on resubscribe.
  token          String    @unique @default(cuid())
  /// Set when the user clicks the confirm link. Until then, no emails are sent.
  confirmedAt    DateTime?
  /// Set when the user clicks unsubscribe. Soft-delete; we keep the row to
  /// avoid resending after unsubscribe.
  unsubscribedAt DateTime?
  /// IP at signup — for rate limit + abuse triage.
  signupIp       String?
  /// Free-text source label e.g. "footer", "popup", "imported".
  source         String?
  /// Last digest sent timestamp — keeps us idempotent if cron runs twice.
  lastSentAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([confirmedAt, unsubscribedAt])
  @@map("newsletter_subscribers")
}

model Sorotan {
  id             String       @id @default(cuid())
  slug           String       @unique
  article        Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId      String
  angle          SorotanAngle
  title          String
  content        String       @db.Text
  indexStatus    String?      @default("pending")
  indexLastError String?
  lastIndexedAt  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([articleId])
  @@index([indexStatus])
  @@map("sorotan")
}

model SocialPost {
  id           String           @id @default(cuid())
  article      Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId    String
  platform     SocialPlatform
  status       SocialPostStatus
  externalId   String?
  imageUrl     String?
  caption      String?          @db.Text
  publishedAt  DateTime?
  errorMessage String?
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([articleId])
  @@index([platform, status])
  @@map("social_posts")
}

model SocialTemplate {
  id            String         @id @default(cuid())
  name          String
  platform      SocialPlatform
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId    String?
  backgroundUrl String         @db.Text
  textLayers    Json
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([platform, isActive])
  @@index([categoryId])
  @@map("social_templates")
}

model SocialMediaSettings {
  id                 String   @id @default("global")
  draftMode          Boolean  @default(true)
  autoPublishIG      Boolean  @default(false)
  autoPublishFB      Boolean  @default(false)
  autoPublishTwitter Boolean  @default(false)
  defaultHashtags    String?  @db.Text
  defaultCTA         String?  @db.Text
  updatedAt          DateTime @updatedAt

  @@map("social_media_settings")
}

model InstagramSettings {
  id                String    @id @default("global")
  accessToken       String?   @db.Text
  igUserId          String?
  templateDefaultId String?
  enabled           Boolean   @default(false)
  captionMaxLen     Int       @default(2200)
  hashtagCount      Int       @default(15)
  tokenExpiresAt    DateTime?
  updatedAt         DateTime  @updatedAt

  @@map("instagram_settings")
}

model FacebookSettings {
  id                String    @id @default("global")
  pageId            String?
  accessToken       String?   @db.Text
  postMode          String    @default("link")
  templateDefaultId String?
  enabled           Boolean   @default(false)
  tokenExpiresAt    DateTime?
  updatedAt         DateTime  @updatedAt

  @@map("facebook_settings")
}

model CourtSchedule {
  id          String              @id @default(cuid())
  caseName    String
  caseNumber  String?
  courtName   String
  scheduledAt DateTime
  status      CourtScheduleStatus @default(SCHEDULED)
  notes       String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([scheduledAt])
  @@index([status])
  @@map("court_schedules")
}

model TargetKeyword {
  id              String    @id @default(cuid())
  keyword         String    @unique
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId      String?
  priority        Int       @default(0)
  isActive        Boolean   @default(true)
  lastGeneratedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, priority])
  @@index([categoryId])
  @@map("target_keywords")
}

/// External news source the cron should periodically scrape, paraphrase
/// and turn into Kartawarta drafts. One row per upstream listing URL
/// (e.g. https://www.bankbjb.co.id/page/berita).
model NewsSource {
  id                 String    @id @default(cuid())
  name               String
  listingUrl         String    @unique
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId         String?
  description        String?
  isActive           Boolean   @default(true)
  priority           Int       @default(0)
  /// How often the cron should re-check this source. Range 1–24 hours.
  frequencyHours     Int       @default(4)
  /// Render JavaScript via headless Chromium before scraping. Required for
  /// SPA sites (e.g. bankbjb.co.id) whose article cards are injected by
  /// client-side JS. Roughly 5–10× slower than the static fetcher.
  useHeadless        Boolean   @default(false)
  /// CSS selector to wait for after the page loads when in headless mode.
  /// Helps with lazy-loaded listings.
  waitForSelector    String?
  /// Follow sub-category links from the listing page and aggregate their
  /// article candidates too (1-level deep BFS). Useful for sites like
  /// bandung.go.id whose root listing links to per-category pages
  /// (/news/infrastruktur, /news/olahraga, etc.). Capped at
  /// `crawlMaxPages` total pages.
  crawlSubcategories Boolean   @default(false)
  /// Hard cap on pages visited during a crawl (root + sub-listings).
  /// Anything more turns into "we're scraping their entire site".
  crawlMaxPages      Int       @default(8)
  /// How many paginated pages to follow on the listing page itself
  /// (e.g. /media?page=1, /media?page=2, …). 1 = no pagination follow
  /// (just the root). Useful for archives like persib.co.id/media that
  /// have 1000+ pages — set to e.g. 5 for the 5 most recent pages.
  paginationMaxPages Int       @default(1)
  /// Optional explicit pagination URL template, e.g. "?page={n}" or
  /// "/page/{n}". When null, the scraper auto-detects from the URL
  /// (?page=, ?p=, /page/) or defaults to "?page={n}".
  paginationPattern  String?
  /// Optional manual CSS selectors when auto-detect fails.
  articleSelector    String?
  titleSelector      String?
  contentSelector    String?
  imageSelector      String?
  /// URLs we have already paraphrased — used to dedup.
  scrapedUrls        String[]  @default([])
  totalScraped       Int       @default(0)
  defaultTags        String[]  @default([])
  lastCheckedAt      DateTime?
  lastSuccessAt      DateTime?
  lastError          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([isActive, priority])
  @@index([categoryId])
  @@map("news_sources")
}

enum GlossaryRanah {
  PIDANA
  PERDATA
  HTN
  HI
  PROSEDUR
  UMUM
}

model Glossary {
  id           String        @id @default(cuid())
  slug         String        @unique
  istilah      String
  singkatan    String?
  bahasaAsli   String?       @map("bahasa_asli")
  ranah        GlossaryRanah @default(UMUM)
  // Body in HTML (sanitized) — sync script converts markdown → HTML
  bodyHtml     String        @db.Text
  // Source markdown for diff/audit when re-syncing
  bodyMarkdown String?       @db.Text
  // Tags for filter (e.g., ["pidana", "kuhap"])
  tags         String[]      @default([])
  // Cross-link: related glossary slugs
  related      String[]      @default([])
  // Source file path in editorial vault
  sourcePath   String?
  // Visibility — admin can hide drafts
  isPublished  Boolean       @default(true)
  viewCount    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ranah, isPublished])
  @@index([istilah])
  @@map("glossary")
}

// ─────────────────────────────────────────────────────────────────────────────
// TikTok Automation
// ─────────────────────────────────────────────────────────────────────────────
// Phase 1 (current): manual workflow — staff upload media, set caption/hashtags/music,
//   export ZIP for posting via TikTok mobile app or CapCut. NO direct API posting yet.
// Phase 2 (next): auto-render videos via @heygen-com/hyperframes from chosen template.
// Phase 3 (next): direct posting via TikTok Content Posting API (requires audit).
// See docs/TIKTOK_AUTOMATION.md for full plan.

enum TiktokAccountStatus {
  CONNECTED
  TOKEN_EXPIRED
  REVOKED
}

enum TiktokContentStatus {
  DRAFT // staff still editing
  READY // ready to export / queue render
  RENDERING // Phase 2: hyperframes job running
  RENDER_FAILED // Phase 2: render error
  SCHEDULED // queued for autopost at scheduledAt
  PUBLISHING // Phase 3: API upload in progress
  PUBLISHED // Phase 3: live on TikTok
  PUBLISH_FAILED // Phase 3: API upload error
  ARCHIVED
}

enum TiktokAspectRatio {
  PORTRAIT_9_16 // 1080x1920 — default TikTok feed
  SQUARE_1_1 // 1080x1080
}

enum TiktokMediaKind {
  IMAGE
  VIDEO
}

model TiktokAccount {
  id             String              @id @default(cuid())
  // Owner is the Kartawarta staff user who connected the TikTok handle.
  ownerId        String
  ownerName      String
  // TikTok-side identifiers (filled in Phase 3 after OAuth)
  platformUserId String?             @unique
  username       String // e.g. "kartawarta_id"
  displayName    String
  avatarUrl      String?
  scopes         String              @default("") // comma-sep
  accessToken    String?             @db.Text
  refreshToken   String?             @db.Text
  expiresAt      DateTime?
  status         TiktokAccountStatus @default(CONNECTED)
  contents       TiktokContent[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([ownerId])
  @@map("tiktok_accounts")
}

model TiktokContent {
  id              String              @id @default(cuid())
  accountId       String?
  account         TiktokAccount?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  // Editorial fields
  title           String // internal label for staff
  caption         String?             @db.Text // TikTok caption (max 2200)
  hashtags        String              @default("") // comma-sep, "hukum,bandung"
  // Optional: derived from / linked to an Article
  sourceArticleId String?
  // Output settings
  aspectRatio     TiktokAspectRatio   @default(PORTRAIT_9_16)
  duration        Int? // seconds, set after render
  templateKey     String? // matches TiktokTemplate.key (Phase 2)
  // Render output (Phase 2)
  outputUrl       String?
  thumbnailUrl    String?
  // Audio
  bgmUrl          String?
  bgmVolume       Float               @default(0.6)
  // Overlay & per-slot text — flexible JSON
  overlayJson     Json?
  // Lifecycle
  status          TiktokContentStatus @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  platformPostId  String?
  publishError    String?             @db.Text
  // Authorship
  createdById     String
  createdByName   String
  slots           TiktokMediaSlot[]
  renderJobs      TiktokRenderJob[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([accountId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdById])
  @@map("tiktok_contents")
}

model TiktokMediaSlot {
  id          String          @id @default(cuid())
  contentId   String
  content     TiktokContent   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  order       Int             @default(0)
  kind        TiktokMediaKind
  url         String          @db.Text
  filename    String?
  mimeType    String?
  // Display tuning
  durationMs  Int             @default(3000) // image: total on-screen, video: ignored
  trimStartMs Int             @default(0)
  trimEndMs   Int?
  caption     String?         @db.Text // optional text overlay for this slot
  width       Int?
  height      Int?
  size        Int?
  createdAt   DateTime        @default(now())

  @@index([contentId])
  @@index([contentId, order])
  @@map("tiktok_media_slots")
}

model TiktokTemplate {
  id            String            @id @default(cuid())
  // Stable identifier used by hyperframes renderer (Phase 2)
  key           String            @unique
  name          String
  description   String?           @db.Text
  // Path on disk to the HTML template (resolved by render worker, Phase 2)
  htmlPath      String?
  // Slot rules
  minSlots      Int               @default(1)
  maxSlots      Int               @default(10)
  acceptedKinds String            @default("IMAGE,VIDEO")
  aspectRatio   TiktokAspectRatio @default(PORTRAIT_9_16)
  thumbnailUrl  String?
  isActive      Boolean           @default(true)
  order         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("tiktok_templates")
}

model TiktokRenderJob {
  id           String        @id @default(cuid())
  contentId    String
  content      TiktokContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  status       String        @default("QUEUED") // QUEUED, RUNNING, SUCCEEDED, FAILED
  progress     Int           @default(0)
  outputUrl    String?
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?       @db.Text
  workerId     String?
  createdAt    DateTime      @default(now())

  @@index([contentId])
  @@index([status])
  @@map("tiktok_render_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Push Notifications — Web Push API subscriptions
// ─────────────────────────────────────────────────────────────────────────────

model PushSubscription {
  id            String    @id @default(cuid())
  endpoint      String    @unique @db.Text // unique URL dari browser push service
  p256dh        String    @db.Text // public key untuk encryption
  auth          String    @db.Text // auth secret
  userAgent     String?   @db.Text // browser/device info untuk debug
  ip            String? // for rate limit
  categorySlugs String?   @db.Text // CSV: "hukum,bisnis-ekonomi" — kategori yang di-subscribe. Null = semua.
  isActive      Boolean   @default(true)
  lastNotifAt   DateTime?
  failureCount  Int       @default(0) // increment kalau push fail; auto-disable kalau >5
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Article Reactions — emoji engagement bar (Sprint 1B)
// ─────────────────────────────────────────────────────────────────────────────

enum ReactionType {
  LIKE
  LOVE
  SAD
  ANGRY
  THINKING
}

model ArticleReaction {
  id          String       @id @default(cuid())
  articleId   String
  type        ReactionType
  ip          String
  fingerprint String?
  createdAt   DateTime     @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, ip, type])
  @@index([articleId])
  @@index([articleId, type])
  @@map("article_reactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Earnings & IPO Calendar — kalender event emiten Indonesia (Sprint 2B)
// ─────────────────────────────────────────────────────────────────────────────

enum MarketEventType {
  EARNINGS // Release laporan keuangan kuartalan / tahunan
  IPO // Initial Public Offering
  RUPS // Rapat Umum Pemegang Saham
  DIVIDEND // Pengumuman dividen / cum-dividend / ex-dividend
  STOCK_SPLIT // Stock split / reverse split
  RIGHTS_ISSUE // Hak memesan efek terlebih dahulu
  OTHER
}

model MarketEvent {
  id          String          @id @default(cuid())
  type        MarketEventType
  ticker      String? // emiten code, e.g. BBRI, BMRI (null untuk macro event)
  companyName String // nama lengkap, e.g. "Bank Rakyat Indonesia"
  title       String // headline event, e.g. "Release Laporan Q1 2026"
  description String?         @db.Text
  scheduledAt DateTime // tanggal/waktu event
  endsAt      DateTime? // optional end time (untuk RUPS multi-day)
  source      String? // URL source kalau ada (IDX press release, etc)
  articleId   String? // optional link ke artikel coverage
  isPublished Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([scheduledAt])
  @@index([type, scheduledAt])
  @@index([ticker])
  @@index([isPublished, scheduledAt])
  @@map("market_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Pejabat Publik Database — direktori pejabat daerah & nasional (Sprint 3B)
// ─────────────────────────────────────────────────────────────────────────────

enum OfficialLevel {
  NASIONAL // Presiden, Menteri, DPR-RI
  PROVINSI // Gubernur, DPRD Provinsi
  KOTA_KABUPATEN // Walikota, Bupati, DPRD Kab/Kota
  KECAMATAN // Camat, Lurah
  YUDIKATIF // Hakim, Jaksa, Polisi (regional)
  LEMBAGA // Komisioner KPK, KPU, dll
  OTHER
}

enum OfficialStatus {
  AKTIF
  PURNA // sudah selesai jabatan
  CUTI // cuti tertentu
  NONAKTIF // diberhentikan
}

model PublicOfficial {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  fullName        String? // versi lengkap (gelar)
  position        String // jabatan saat ini, e.g. "Walikota Bandung"
  institution     String // institusi, e.g. "Pemerintah Kota Bandung"
  level           OfficialLevel
  region          String? // wilayah, e.g. "Kota Bandung", "Jawa Barat"
  status          OfficialStatus @default(AKTIF)
  termStart       DateTime? // mulai jabatan
  termEnd         DateTime? // berakhir jabatan
  bio             String?        @db.Text
  birthplace      String?
  birthdate       DateTime?
  education       String?        @db.Text // CSV / multi-line
  career          String?        @db.Text
  party           String? // partai politik (kalau ada)
  photoUrl        String?
  websiteUrl      String?
  twitterHandle   String?
  instagramHandle String?
  isPublished     Boolean        @default(true)
  viewCount       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([level, status])
  @@index([region])
  @@index([institution])
  @@index([isPublished, level])
  @@map("public_officials")
}

// ─────────────────────────────────────────────────────────────────────────────
// Regulasi Tracker — UU, PP, Perpres, Permen, Perda Indonesia (Sprint 3A)
// ─────────────────────────────────────────────────────────────────────────────

enum RegulationType {
  UU // Undang-Undang
  PERPPU // Peraturan Pemerintah Pengganti UU
  PP // Peraturan Pemerintah
  PERPRES // Peraturan Presiden
  KEPPRES // Keputusan Presiden
  INPRES // Instruksi Presiden
  PERMEN // Peraturan Menteri
  KEPMEN // Keputusan Menteri
  PERDA_PROV // Perda Provinsi
  PERDA_KAB // Perda Kabupaten/Kota
  PERGUB // Peraturan Gubernur
  PERWAL // Peraturan Walikota / Bupati
  PUTUSAN_MK // Putusan Mahkamah Konstitusi
  PUTUSAN_MA // Putusan Mahkamah Agung
  OTHER
}

enum RegulationStatus {
  DRAFT_RUU // Masih RUU
  ENACTED // Sudah diundangkan, berlaku
  AMENDED // Sudah diubah / direvisi
  REVOKED // Dicabut / dibatalkan
}

model Regulation {
  id          String           @id @default(cuid())
  type        RegulationType
  number      String // e.g. "27/2022", "13 Tahun 2003"
  year        Int
  title       String           @db.Text
  shortTitle  String? // e.g. "UU PDP"
  topic       String? // e.g. "Privasi", "Tenaga Kerja", "Pajak"
  description String?          @db.Text
  enactedAt   DateTime? // tanggal diundangkan
  effectiveAt DateTime? // tanggal mulai berlaku
  issuedBy    String? // institusi penerbit, e.g. "Pemerintah", "MK"
  status      RegulationStatus @default(ENACTED)
  sourceUrl   String? // link ke peraturan.go.id atau JDIH
  pdfUrl      String? // link langsung ke PDF
  articleId   String? // optional link ke artikel coverage
  isPublished Boolean          @default(true)
  viewCount   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([type, number, year])
  @@index([type, year(sort: Desc)])
  @@index([status])
  @@index([topic])
  @@index([isPublished, enactedAt(sort: Desc)])
  @@map("regulations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Live Blog — siaran langsung peristiwa (Sprint 4A)
// ─────────────────────────────────────────────────────────────────────────────

enum LiveBlogStatus {
  SCHEDULED // belum mulai
  LIVE // sedang berjalan
  ENDED // sudah selesai
  CANCELLED // dibatalkan
}

model LiveBlog {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String?        @db.Text
  category    String? // e.g. "Sidang", "Demo", "Konferensi"
  status      LiveBlogStatus @default(SCHEDULED)
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  coverImage  String?
  authorId    String // siapa yang liput
  articleId   String? // optional link ke artikel terkait
  isPublished Boolean        @default(true)
  viewCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  entries LiveBlogEntry[]
  author  User            @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([status, scheduledAt(sort: Desc)])
  @@index([isPublished, status])
  @@index([authorId])
  @@map("live_blogs")
}

model LiveBlogEntry {
  id          String   @id @default(cuid())
  liveBlogId  String
  content     String   @db.Text // konten update (HTML allowed, sanitized)
  postedAt    DateTime @default(now())
  authorId    String?
  isPinned    Boolean  @default(false)
  isHighlight Boolean  @default(false)
  imageUrl    String?
  videoUrl    String?

  liveBlog LiveBlog @relation(fields: [liveBlogId], references: [id], onDelete: Cascade)

  @@index([liveBlogId, postedAt(sort: Desc)])
  @@index([liveBlogId, isPinned, postedAt(sort: Desc)])
  @@map("live_blog_entries")
}

# WordPress sensitive files
www/wp-config.php
www/wp-content/debug.log
www/wp-content/cache/
www/wp-content/uploads/
www/wp-content/upgrade/
www/wp-content/backups/
www/wp-content/backup-db/
www/wp-content/advanced-cache.php
www/wp-content/wp-cache-config.php
www/wp-content/plugins/backuply-pro/
www/wp-content/plugins/cookieadmin-pro/
www/wp-content/plugins/gosmtp-pro/
www/wp-content/plugins/loginizer-security/

# Environment
.env
.env.local
.env.production
.env.*.local

# Node (untuk project Next.js nanti)
node_modules/
.next/
out/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Hosting directories (sensitive)
access-logs/
db/
logs/
mail/
public_html/
ssl/
tmp/
etc/

# Old WordPress files (will be replaced by Next.js)
www/

# Uploaded files
public/uploads/*
!public/uploads/.gitkeep

# Operational scripts that may contain credentials — keep off-repo
# Whitelist only the safe shell scripts that don't carry secrets.
scripts/*
!scripts/backup-db.sh
!scripts/backup-verify.sh
!scripts/backup-restore-drill.sh
!scripts/backup-uploads.sh
!scripts/backup-offsite.sh
!scripts/safe-db-push.sh
!scripts/deploy-vps.sh
!scripts/maintenance-server.js
!scripts/maintenance-page.html
!scripts/test-instagram.js
!scripts/exchange-threads.js
!scripts/.gitkeep

# Playwright artifacts
tests/e2e/.results/
tests/e2e/.report/
playwright-report/
test-results/

# Obsidian (personal config — each user has their own)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json
.trash/

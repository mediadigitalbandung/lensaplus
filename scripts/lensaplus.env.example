# ==============================================================================
# Lensaplus Production Environment Variables
# ==============================================================================
# Copy this file to /var/www/lensaplus/.env and fill in the values before deploying.
# After updating, run `pm2 restart lensaplus`.

# ------------------------------------------------------------------------------
# Database & Core Settings
# ------------------------------------------------------------------------------
# PostgreSQL database connection URL (configured by scripts/vps-setup.sh)
DATABASE_URL="postgresql://lensaplus:YOUR_DB_PASSWORD@localhost:5432/lensaplus"

# Canonical URL of the application (required for SEO & API endpoints)
NEXT_PUBLIC_APP_URL="https://lensaplus.com"

# ------------------------------------------------------------------------------
# NextAuth Settings
# ------------------------------------------------------------------------------
# Canonical base URL for NextAuth callbacks
NEXTAUTH_URL="https://lensaplus.com"

# Secret key used to encrypt NextAuth tokens (Generate with: openssl rand -hex 32)
NEXTAUTH_SECRET="your_nextauth_hex_secret_here"

# ------------------------------------------------------------------------------
# Security & Encryption Settings
# ------------------------------------------------------------------------------
# Key used to encrypt external API credentials and secrets in the database.
# Must be exactly a base64-encoded 32-byte string.
# Generate with: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY="your_base64_32_bytes_key_here"

# Enforce single session per user (cancels previous session when logging in elsewhere)
SINGLE_DEVICE_ENFORCEMENT="false"

# ------------------------------------------------------------------------------
# Cron Scheduling Secret
# ------------------------------------------------------------------------------
# Secret token to protect cron API endpoints. Must match what is in crontab.
# Generate with: openssl rand -hex 32
CRON_SECRET="your_cron_secret_token_here"

# ------------------------------------------------------------------------------
# Backups & Notifications
# ------------------------------------------------------------------------------
# Optional webhook for backup status alerts (Discord or Slack format)
BACKUP_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"

# Optional rclone target name and bucket for off-site backup storage.
# Set up rclone first by running `rclone config` on the VPS.
OFFSITE_RCLONE_REMOTE="r2:lensaplus-backup"
OFFSITE_RETENTION_DAYS="90"
UPLOADS_RETENTION_DAYS="7"

# ------------------------------------------------------------------------------
# Third-Party Integrations (Optional)
# ------------------------------------------------------------------------------
# Email Sending Service
RESEND_API_KEY=""

# AI models & search engines for automated content creation & transcription
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""
PERPLEXITY_API_KEY=""
DEEPGRAM_API_KEY=""

# Spam & bot protection keys
AKISMET_API_KEY=""
TURNSTILE_SECRET_KEY=""

# Cloudflare Analytics telemetry keys
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""
GA4_PROPERTY_ID=""
GOOGLE_CREDENTIALS_JSON=""
